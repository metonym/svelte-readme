{
  "name": "svelte-readme",
  "version": "3.6.3",
  "license": "MIT",
  "description": "Develop and demo your Svelte components in your README.md",
  "author": "Eric Liu (https://github.com/metonym)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "preprocess": "bun scripts/preprocessStyles.ts",
    "dev": "bun run preprocess && tsgo -w",
    "prepack": "bun run preprocess && tsgo",
    "lint": "biome check --write .",
    "lint:changed": "biome check --write --changed --since=master --no-errors-on-unmatched .",
    "test": "bun test",
    "verify": "bun scripts/verifyPreprocess.ts"
  },
  "dependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "estree-walker": "^3.0.3",
    "html-minifier": "^4.0.0",
    "markdown-it": "^12.3.0",
    "markdown-it-anchor": "^6.0.1",
    "prettier": "^2.5.1",
    "prettier-plugin-svelte": "^2.5.1",
    "prism-svelte": "^0.4.7",
    "prismjs": "^1.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@types/html-minifier": "^4.0.2",
    "@types/markdown-it": "^12.0.1",
    "@types/markdown-it-anchor": "^4.0.4",
    "@types/node": "^14.14.21",
    "@types/prettier": "^2.1.6",
    "@types/prismjs": "^1.16.2",
    "@typescript/native-preview": "^7.0.0-dev.20260703.1",
    "github-markdown-css": "4.0.0",
    "postcss": "^8.2.4",
    "svelte": "^5.56.4",
    "vite": "^8.1.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/metonym/svelte-readme"
  },
  "homepage": "https://github.com/metonym/svelte-readme",
  "bugs": "https://github.com/metonym/svelte-readme/issues",
  "keywords": [
    "svelte",
    "svelte-component",
    "documentation"
  ],
  "files": [
    "dist"
  ]
}
